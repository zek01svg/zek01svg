# ── Supabase / Database ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
# For Cloud Run workers, use the Supabase connection pooler (Transaction mode):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Notifications ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# ── Email (Gmail OAuth2 — store the full credentials JSON as a single-line string) ──
GMAIL_CREDS_PERSONAL={"client_id":"...","client_secret":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token"}
GMAIL_CREDS_SCHOOL={"client_id":"...","client_secret":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token"}

# ── Calendar ───────────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDS={"client_id":"...","client_secret":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token"}
OUTLOOK_TOKEN_JSON={"access_token":"...","refresh_token":"..."}
APPLE_ID=you@icloud.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx    # from appleid.apple.com > App-Specific Passwords

# ── External APIs ──────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=...
EXCHANGERATE_API_KEY=...
GITHUB_TOKEN=ghp_...            # optional but avoids rate limits
BIBLE_API_KEY=...               # api.scripture.api.bible free key

# ── Notion ─────────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_TASK_DB_IDS=db-id-1,db-id-2    # comma-separated Notion database IDs
